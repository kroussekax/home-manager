[
	{
		"include": [
			"/home/kax/dotfiles/modules/waybar/Modules"
		],

		"layer": "top",
		"exclusive": true,
		"passthrough": false,
		"position": "top",
		"spacing": 0,
		"fixed-center": true,
		"ipc": true,
		"margin-top": 0,
		"margin-left": 8,
		"margin-right": 8,

		"modules-left": [
			"hyprland/window"
		],

		"modules-center": [
			"hyprland/workspaces#kanji"
		],

		"modules-right": [
			"tray",
			"bluetooth",
			"pulseaudio",
			"battery",
			"clock"
		]
	}
]
	
